{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "Profile picture URL" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "GalleryImage": {
      "title": "Gallery Image",
      "description": "Metadata for a publicly shared image",
      "type": "object",
      "properties": {
        "url": { "type": "string", "description": "Image URL" },
        "authorId": { "type": "string", "description": "UID of the uploader" },
        "authorName": { "type": "string", "description": "Name of the uploader" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Upload timestamp" }
      },
      "required": ["url", "authorId", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Individual user profile document"
    },
    "public_gallery/{imageId}": {
      "schema": "GalleryImage",
      "description": "Shared images visible to everyone"
    }
  }
}
